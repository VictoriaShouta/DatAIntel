# PostgreSQL
POSTGRES_USER=datAIntel
POSTGRES_PASSWORD=change_me
POSTGRES_DB=datAIntel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://datAIntel:change_me@postgres:5432/datAIntel

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Redpanda (Kafka API uyumlu)
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg://datAIntel:change_me@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# Auth
JWT_SECRET_KEY=change_me_dev_only
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Mock ERP
MOCK_ERP_BASE_URL=http://mock_erp:8001

# Genel
ENVIRONMENT=development
LOG_LEVEL=INFO
